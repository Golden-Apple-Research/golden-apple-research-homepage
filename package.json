{
  "name": "golden-apple-research-homepage",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:db": "pnpm start-db && pnpm studio && pnpm dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "postinstall": "npm run cf-typegen",
    "start-db": "podman run  -p 5432:5432 -e POSTGRES_PASSWORD=password -v pgtest:/var/lib/postgresql/data --rm postgres:alpine",
    "studio": "pnpm drizzle-kit studio",
    "build:cloudflare": "pnpm drizzle-kit push --url $POSTGRES_DIRECT_URL --dialect postgresql --schema src/lib/db/schema.ts --verbose && pnpm build"
  },
  "dependencies": {
